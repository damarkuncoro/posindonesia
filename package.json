{
  "name": "@damarkuncoro/posindonesia",
  "version": "1.0.0",
  "description": "Indonesian Postal Code Scraper from Pos Indonesia Official Website",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/damarkuncoro/posindonesia.git"
  },
  "bugs": {
    "url": "https://github.com/damarkuncoro/posindonesia/issues"
  },
  "homepage": "https://github.com/damarkuncoro/posindonesia#readme",
  "main": "lib/cjs/main.js",
  "module": "lib/esm/main.js",
  "types": "lib/cjs/main.d.ts",
  "exports": {
    ".": {
      "import": "./lib/esm/main.js",
      "require": "./lib/cjs/main.js",
      "types": "./lib/cjs/main.d.ts"
    },
    "./data": {
      "import": "./lib/esm/data/index.js",
      "require": "./lib/cjs/data/index.js",
      "types": "./lib/cjs/data/index.d.ts"
    }
  },
  "scripts": {
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build": "rm -rf lib && npm run build:cjs && npm run build:esm",
    "prepublishOnly": "npm run build && npm test",
    "docs": "typedoc",
    "test": "jest"
  },
  "keywords": [
    "indonesia",
    "postal-code",
    "kodepos",
    "scraper",
    "pos-indonesia",
    "typescript"
  ],
  "author": "damarkuncoro",
  "files": [
    "lib",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "fuse.js": "^7.1.0"
  },
  "devDependencies": {
    "axios": "^1.13.6",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "qs": "^6.15.0",
    "winston": "^3.19.0",
    "@types/axios": "^0.9.36",
    "@types/chalk": "^0.4.31",
    "@types/cheerio": "^0.22.35",
    "@types/cli-progress": "^3.11.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/qs": "^6.15.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  }
}
